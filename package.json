{
  "name": "@tigerdata/mcp-boilerplate",
  "version": "1.3.2",
  "description": "MCP boilerplate code for Node.js",
  "license": "Apache-2.0",
  "author": "TigerData",
  "homepage": "https://tigerdata.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/timescale/mcp-boilerplate-node"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslintPlugin": {
      "import": "./dist/eslintPlugin.js",
      "types": "./dist/eslintPlugin.d.ts"
    },
    "./instrumentation": {
      "import": "./dist/instrumentation.js",
      "types": "./dist/instrumentation.d.ts"
    },
    "./skills": {
      "import": "./dist/skills/index.js",
      "types": "./dist/skills/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "watch": "tsc --watch",
    "lint": "./bun x @biomejs/biome check",
    "test": "./bun test ./src"
  },
  "dependencies": {
    "@mcp-use/inspector": "^0.24.5",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@toon-format/toon": "^2.1.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "raw-body": "^3.0.2",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "zod": "^3.25 || ^4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "zod": "^4.3.6",
    "@octokit/rest": "^22.0.1",
    "@types/bun": "^1.3.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "@typescript-eslint/typescript-estree": "^8.57.1",
    "ai": "^5.0.155",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
